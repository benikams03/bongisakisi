{
    "name": "batelapharma",
    "version": "1.0.0",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev": "npx electron index.js",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.batelapharma.app",
        "productName": "Batelapharma",
        "asar": true,
        "compression": "maximum",
        "copyright": "© 2026 Batelapharma",
        "files": [
            "index.js",
            "preload.js",
            "dist/**/*",
            "src/**/*",
            "node_modules/**/*",
            "package.json",

            "!node_modules/*/{test,__tests__,tests}",
            "!node_modules/*.md",
            "!node_modules/*.ts",
            "!src",
            "!docs"
        ],
        "directories": {
            "buildResources": "assets"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": ["x64"]
                },
                "zip"
            ],
            "publisherName": "Batelapharma SARL",
            "icon": "assets/logo.ico"
        },
        "forceCodeSigning": false, 
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "installerIcon": "assets/logo.ico",
            "uninstallerIcon": "assets/logo.ico",
            "installerHeaderIcon": "assets/logo.ico",
            "deleteAppDataOnUninstall": true
        }
    },
    "keywords": [],
    "author": "Beni mukungulu",
    "license": "ISC",
    "description": "",
    "devDependencies": {
        "electron": "^40.0.0",
        "electron-builder": "^26.4.0"
    },
    "dependencies": {
        "better-sqlite3": "^12.6.2"
    }
}
